# Copy this file to ".env" and fill in the two values from your Supabase project.
#
# VITE_SUPABASE_URL  → click the green "Connect" button at the top of the dashboard,
#                      or Settings → Data API. Looks like https://xxxx.supabase.co
#
# VITE_SUPABASE_ANON_KEY → Settings → API Keys → the "Publishable key" (starts with
#                          sb_publishable_...). It's safe in the browser because RLS is on.
#                          Do NOT use the Secret key (sb_secret_...) here.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key
